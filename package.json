{
  "name": "@zondax/zemu",
  "author": "Zondax AG",
  "license": "Apache-2.0",
  "version": "0.0.0",
  "description": "Zemu Testing Framework",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/zondax/zemu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zondax/zemu.git"
  },
  "keywords": [
    "Zondax",
    "Ledger",
    "Testing",
    "Zemu"
  ],
  "scripts": {
    "build": "bun rimraf dist && tsc && bun copy-files",
    "copy-files": "copyfiles -u 0 src/**/*.proto dist/",
    "test:clean": "bun ts-node tests/pullImageKillOld.ts",
    "test": "bun test:clean && bun build && bun test tests_zemu",
    "test:watch": "bun test --watch",
    "linter": "eslint --max-warnings 0 src/**/*.ts",
    "linter:fix": "bun linter --fix",
    "format": "prettier --write ."
  },
  "bugs": {
    "url": "https://github.com/zondax/zemu/issues"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.13.1",
    "@grpc/proto-loader": "^0.7.13",
    "@ledgerhq/hw-transport-http": "^6.30.4",
    "axios": "^1.8.4",
    "axios-retry": "^4.5.0",
    "dockerode": "^4.0.4",
    "elfy": "^1.0.0",
    "fs-extra": "^11.3.0",
    "get-port": "^7.1.0",
    "pngjs": "^7.0.0",
    "randomstring": "^1.3.1"
  },
  "devDependencies": {
    "@ledgerhq/hw-transport": "^6.31.4",
    "@types/dockerode": "^3.3.35",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.11",
    "@types/pngjs": "^6.0.5",
    "@types/randomstring": "^1.3.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@zondax/ledger-substrate": "^1.0.1",
    "copyfiles": "^2.4.1",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.16.2",
    "eslint-plugin-promise": "^7.2.1",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "5.8.2",
    "vitest": "^3.0.9"
  },
  "files": [
    "dist/**/*"
  ],
  "packageManager": "bun@1.0.30"
}
